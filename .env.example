FLASK_ENV=production
NODE_ENV=production
# 172.18.0.1 = Docker bridge gateway to reach host PostgreSQL from inside container
SQLALCHEMY_DATABASE_URI_PRODUCTION=postgresql://case_explorer:YOUR_DB_PASSWORD@172.18.0.1:5432/mjcs
SQLALCHEMY_DATABASE_URI_DEVELOPMENT=postgresql://case_explorer:YOUR_DB_PASSWORD@172.18.0.1:5432/mjcs
CASE_DETAILS_BUCKET=mjcs-case-details
CASE_DETAILS_DIRECTORY=
BPDWATCH_DATABASE_URI=
# 172.18.0.1 = Docker bridge gateway to reach host MinIO from inside container
MINIO_URL=http://172.18.0.1:9000
BUILD_PRODUCTION=1
